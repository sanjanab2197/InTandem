{
  "buildCommand": "cd couple-planner && npm install && npx expo export -p web",
  "outputDirectory": "couple-planner/dist",
  "installCommand": "cd couple-planner && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!_expo/|assets/|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
